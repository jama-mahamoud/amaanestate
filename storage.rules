rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Listing Assets
    match /listings/{listingId}/{allPaths=**} {
      // Public read access for marketplace visibility
      allow read: if true;
      
      // Allow authenticated users to upload to any listing folder.
      // This is necessary because image uploading often happens before or during document creation.
      allow write: if isSignedIn();
    }

    // Professional Assets
    match /professionals/{profileId}/{allPaths=**} {
      allow read: if true;
      
      // Users can only upload to their own professional profile path
      // Assuming profileId matches request.auth.uid or we check Firestore
      allow write: if isOwner(profileId);
    }
    
    // User Profile Assets
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
