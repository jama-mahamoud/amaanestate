{
  "entities": {
    "EditorialReview": {
      "title": "Editorial Review",
      "description": "A structured affiliate review or market insight column.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique slug for the review." },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["draft", "pending", "approved", "rejected", "archived", "published"] 
        },
        "category": { 
          "type": "string"
        },
        "featuredImage": { "type": "string" },
        "excerpt": { "type": "string" },
        "introduction": { "type": "string" },
        "whatIsIt": { "type": "string" },
        "keyFeatures": { "type": "array", "items": { "type": "string" } },
        "pros": { "type": "array", "items": { "type": "string" } },
        "cons": { "type": "array", "items": { "type": "string" } },
        "bestFor": { "type": "string" },
        "pricingOverview": { "type": "string" },
        "finalVerdict": { "type": "string" },
        "rating": { "type": "number" },
        "readingTime": { "type": "string" },
        "publishDate": { "type": "string" },
        "brandName": { "type": "string" },
        "brandLogoLetter": { "type": "string" },
        "affiliateUrl": { "type": "string" },
        "ctaSummary": { "type": "string" },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "status", "category"]
    },
    "StrategicTerm": {
      "title": "Strategic Term",
      "description": "A glossary term defining legal, technical, or financial real estate terminology.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique term ID or slug" },
        "term": { "type": "string" },
        "acronym": { "type": "string" },
        "definition": { "type": "string" },
        "category": { "type": "string" },
        "relatedTerms": { "type": "array", "items": { "type": "string" } },
        "contextualLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            },
            "required": ["label", "url"]
          }
        },
        "status": {
          "type": "string",
          "enum": ["draft", "published"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["term", "definition", "category", "status"]
    }
  },
  "firestore": {
    "/editorial_reviews/{id}": {
      "schema": "EditorialReview",
      "description": "Editorial partner reviews and market insights."
    },
    "/strategic_terms/{id}": {
      "schema": "StrategicTerm",
      "description": "Strategic real estate and legal glossary definitions."
    }
  }
}
