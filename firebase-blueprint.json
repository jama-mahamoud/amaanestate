{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users and agents",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "agent", "admin"] },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate listings",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "listingType": { "type": "string", "enum": ["sale", "rent"] },
        "city": { "type": "string" },
        "location": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "area": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "published", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Automobile listings",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "title": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "price": { "type": "number" },
        "listingType": { "type": "string" },
        "city": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles and roles" },
    "properties": { "schema": "Property", "description": "Property listings" },
    "vehicles": { "schema": "Vehicle", "description": "Vehicle listings" },
    "articles": { "schema": "object", "description": "Blog posts and news" },
    "inquiries": { "schema": "object", "description": "Lead inquiries" }
  }
}
