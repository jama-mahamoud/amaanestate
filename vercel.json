{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/index?path=sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index?path=robots.txt"
    },

    {
      "source": "/news/:slug",
      "destination": "/api/index?path=news&slug=:slug"
    },
    {
      "source": "/properties/:id",
      "destination": "/api/index?path=properties&id=:id"
    },
    {
      "source": "/vehicles/:id",
      "destination": "/api/index?path=vehicles&id=:id"
    },
    {
      "source": "/agents/:id",
      "destination": "/api/index?path=agents&id=:id"
    },

    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },

    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
