rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Reusable Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && (
      exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
      request.auth.token.email.lower() == 'towinnow0@gmail.com'
    ); }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function docData(path) { return get(path).data; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -- VALIDATION HELPERS --
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.email is string && data.role is string;
    }

    function isValidListing(data) {
      return data.keys().hasAll(['title', 'category', 'price', 'ownerId', 'status', 'createdAt']) &&
             data.price is number && data.ownerId is string;
    }

    function isValidEditorialReview(data) {
      return data.keys().hasAll(['title', 'slug', 'status', 'category']) &&
             data.title is string && data.slug is string &&
             data.status in ['draft', 'pending', 'approved', 'rejected', 'archived'] &&
             data.category in ['real-estate', 'finance', 'tech', 'learning', 'market'] &&
             (data.get('rating', 0) is number || data.get('rating', 0) is int);
    }

    // -- COLLECTIONS --

    // USER PROFILES
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        !incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin()
      );
    }

    // -- ADMINS --
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -- LISTINGS (Properties, Vehicles, etc) --
    match /listings/{listingId} {
      allow read: if true; // Public marketplace
      allow create: if isSignedIn() && isValidListing(incoming());
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // -- JOBS --
    match /jobs/{jobId} {
      allow read: if true; // Public board
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // -- COMPANIES --
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // -- NOTIFICATIONS --
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        (isAdmin() && existing().userId == 'admin')
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        (isAdmin() && existing().userId == 'admin')
      );
    }

    // -- AGREEMENTS --
    match /agreements/{agreementId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          existing().partyA.uid == request.auth.uid || 
          existing().partyB.uid == request.auth.uid || 
          existing().createdBy == request.auth.uid
        )
      );
      allow list: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // -- BROKERS --
    match /brokers/{brokerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().userId == request.auth.uid;
    }
    
    // -- BROKER APPLICATIONS --
    match /brokerApplications/{applicationId} {
      allow read: if isAdmin() || isOwner(existing().userId);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // -- EDITORIAL REVIEWS --
    match /editorial_reviews/{id} {
      allow get: if isAdmin() || (existing().status == 'approved');
      allow list: if isAdmin() || (resource.data.status == 'approved');
      allow create: if isAdmin() && isValidEditorialReview(incoming());
      allow update: if isAdmin() && (
        isValidEditorialReview(incoming()) || 
        // Allow public to increment views/clicks if we implement increment logic later
        // For now, only admin can write to metrics via service
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'clicks', 'ctr', 'bannerClicks', 'ctaButtons'])
      );
      allow delete: if isAdmin();
    }

    // -- AUDIT LOGS --
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // -- GLOBAL STATS --
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -- ARTICLES --
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -- CONTACT MESSAGES --
    match /contactMessages/{messageId} {
      allow create: if true; // Public contact
      allow read, write: if isAdmin();
    }

    // -- INQUIRIES --
    match /inquiries/{inquiryId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid;
      allow write: if isAdmin() || existing().senderId == request.auth.uid;
    }

    // -- CANDIDATE PROFILES --
    match /candidateProfiles/{candidateId} {
      allow read: if true; // Public for recruiters
      allow write: if isAdmin() || isOwner(candidateId);
    }

    // -- JOB APPLICATIONS --
    match /jobApplications/{applicationId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || existing().candidateId == request.auth.uid || exists(/databases/$(database)/documents/companies/$(existing().companyId)) && get(/databases/$(database)/documents/companies/$(existing().companyId)).data.ownerId == request.auth.uid;
      allow update: if isAdmin() || (exists(/databases/$(database)/documents/companies/$(existing().companyId)) && get(/databases/$(database)/documents/companies/$(existing().companyId)).data.ownerId == request.auth.uid);
    }
  }
}
