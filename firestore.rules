rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'createdAt', 'photoURL', 'isVerified'])
        && data.keys().size() == 7
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.role in ['buyer', 'seller', 'agent', 'admin']
        && data.displayName is string && data.displayName.size() <= 100
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && data.isVerified is bool;
    }

    function isValidListing(data) {
      return data.keys().hasAll(['title', 'category', 'price', 'city', 'listingType', 'ownerId', 'status', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.category in ['property', 'rental', 'land', 'vehicle']
        && data.price is number && data.price >= 0
        && data.city is string && data.city.size() <= 100
        && data.listingType in ['sale', 'rent']
        && data.ownerId == request.auth.uid
        && data.status in ['pending', 'active', 'sold', 'rented', 'archived']
        && (data.isFeatured == null || data.isFeatured == false || isAdmin());
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'category', 'description', 'providerId', 'status', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.category in ['Construction & Engineering', 'Interior Design & Renovation', 'Legal & Financial Advisory', 'Logistics & Supply Chain']
        && data.providerId == request.auth.uid
        && data.status in ['active', 'pending', 'inactive']
        && data.createdAt == request.time;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['listingId', 'senderId', 'receiverId', 'message', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.message is string && data.message.size() <= 2000;
    }

    // Collection Security
    match /users/{userId} {
      // 8. Secure List Queries
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().role == 'buyer'
        && incoming().createdAt == request.time
        && incoming().isVerified == false;

      allow update: if isOwner(userId) && (
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        && incoming().displayName is string && incoming().displayName.size() <= 100
        && (incoming().photoURL == null || (incoming().photoURL is string && incoming().photoURL.size() <= 1000))
      ) || isAdmin();

      // Deny deletion by users, only admins can delete
      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if resource.data.status == 'active' || isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isSignedIn() 
        && isValidListing(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      
      allow update: if (
        isOwner(existing().ownerId) && (
          // Owners can only update basic details
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'currency', 'city', 'location', 'images', 'features', 'updatedAt'])
        )
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /professionalServices/{serviceId} {
      allow read: if resource.data.status == 'active' || isOwner(resource.data.providerId) || isAdmin();
      allow create: if isSignedIn() && isValidService(incoming());
      allow update: if (
        isOwner(existing().providerId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'updatedAt'])
          && incoming().updatedAt == request.time
        )
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isOwner(resource.data.senderId) || isOwner(resource.data.receiverId) || isAdmin();
      allow create: if isSignedIn() && isValidInquiry(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
