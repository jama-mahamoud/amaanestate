rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Core Functions & RBAC
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Attempt to read the user's role from the users collection
    // If the document doesn't exist yet (during registration), default to 'normal_user'
    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'normal_user';
    }
    
    function hasRole(roleName) {
      return isSignedIn() && getRole() == roleName;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        hasRole('admin') 
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isEditor() {
      return isAdmin() || hasRole('editor');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'createdAt'])
        && data.uid == request.auth.uid
        && data.role in ['admin', 'editor', 'agent', 'verified_professional', 'normal_user']
        && data.displayName is string && data.displayName.size() <= 100
        && (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (!('isVerified' in data) || data.isVerified is bool);
    }

    function isValidListing(data) {
      let allowedFields = ['title', 'description', 'category', 'price', 'currency', 'city', 'location', 
                           'listingType', 'ownerId', 'status', 'createdAt', 'updatedAt', 'images', 'features', 
                           'isFeatured', 'metadata', 'subcategory', 'year', 'mileage', 
                           'fuelType', 'transmission', 'beds', 'baths', 'size',
                           'isVerified', 'verificationStatus', 'legalChecked', 'ownershipVerified'];
                           
      return data.keys().hasAll(['title', 'category', 'price', 'city', 'listingType', 'ownerId', 'status', 'createdAt', 'images'])
        && data.title is string && data.title.size() <= 200
        && data.category in ['property', 'rental', 'land', 'vehicle']
        && data.price is number && data.price >= 0
        && data.city is string && data.city.size() <= 100
        && data.listingType in ['sale', 'rent']
        && data.ownerId == request.auth.uid
        && data.status in ['pending', 'active', 'sold', 'rented', 'archived']
        && data.images is list
        && data.keys().hasOnly(allowedFields)
        && (!('description' in data) || data.description is string)
        && (!('year' in data) || data.year is number)
        && (!('mileage' in data) || data.mileage is string)
        && (!('beds' in data) || data.beds is number)
        && (!('baths' in data) || data.baths is number)
        && (!('isVerified' in data) || data.isVerified is bool)
        && (!('verificationStatus' in data) || data.verificationStatus in ['pending', 'verified', 'rejected'])
        && (!('legalChecked' in data) || data.legalChecked is bool)
        && (!('ownershipVerified' in data) || data.ownershipVerified is bool);
    }
    
    function isValidService(data) {
      return data.keys().hasAll(['title', 'category', 'description', 'providerId', 'status', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.providerId == request.auth.uid
        && data.status in ['active', 'pending', 'inactive'];
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['listingId', 'senderId', 'receiverId', 'message', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.message is string && data.message.size() <= 2000;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['type', 'userId', 'status', 'data', 'createdAt'])
        && data.type in ['agent', 'professional']
        && data.userId == request.auth.uid
        && data.status in ['pending', 'pending_review'];
    }
    
    function isValidProfessional(data) {
      let allowedFields = ['name', 'title', 'category', 'city', 'image', 'isVerified', 'uid', 'bio', 'skills', 'experienceYears', 'whatsapp', 'phone', 'email', 'availability'];

      return data.keys().hasAll(['name', 'title', 'category', 'city', 'uid'])
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.title is string && data.title.size() <= 100
        && data.city is string && data.city.size() <= 100
        && data.keys().hasOnly(allowedFields);
    }

    function isValidArticle(data) {
      let allowedFields = ['title', 'slug', 'summary', 'content', 'category', 'language', 'featuredImage', 'gallery', 'tags', 'seoTitle', 'seoDescription', 'authorId', 'isFeatured', 'published', 'views', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(['title', 'slug', 'content', 'category', 'language', 'authorId', 'published', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.slug is string && data.slug.size() <= 100
        && data.content is string
        && data.category is string
        && data.language in ['en', 'so']
        && data.authorId == request.auth.uid
        && data.published is bool
        && data.keys().hasOnly(allowedFields);
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['fullName', 'email', 'inquiryType', 'message', 'status', 'createdAt'])
        && data.fullName is string
        && data.email is string
        && data.inquiryType is string
        && data.message is string
        && data.status in ['unread', 'read', 'archived']
        && (!('userId' in data) || data.userId == null || data.userId == request.auth.uid);
    }

    // 3. Collection Security Strategies

    // Users Collection
    match /users/{userId} {
      // safe public fields reading where appropriate
      allow get: if true; 
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().role == 'normal_user'; // Enforce default role on creation
      allow update: if (isOwner(userId) && !('role' in incoming().diff(existing()).affectedKeys())) || isAdmin();
      allow delete: if isAdmin();
    }

    // Professionals Directory
    match /professionals/{profileId} {
      allow read: if true;
      allow create: if isOwner(profileId) && isValidProfessional(incoming());
      allow update: if (isOwner(profileId) && !('isVerified' in incoming().diff(existing()).affectedKeys())) || isAdmin();
      allow delete: if isAdmin();
    }

    // Listings System
    match /listings/{listingId} {
      allow read: if (resource.data.status == 'active' && resource.data.verificationStatus == 'verified') || (isSignedIn() && isOwner(resource.data.ownerId)) || isAdmin();
      allow create: if isSignedIn() 
        && isValidListing(incoming())
        && incoming().status == 'pending'
        && incoming().verificationStatus == 'pending'
        && incoming().isVerified == false
        && incoming().legalChecked == false
        && incoming().ownershipVerified == false;
      allow update: if (
        isOwner(existing().ownerId) && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'title', 'description', 'price', 'currency', 'city', 'location', 
            'images', 'features', 'updatedAt', 'metadata', 'subcategory',
            'year', 'mileage', 'fuelType', 'transmission', 'beds', 'baths', 'size', 'status'
          ]) // Owner cannot change 'isFeatured'
        )
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Services
    match /professionalServices/{serviceId} {
      allow read: if resource.data.status == 'active' || (isSignedIn() && isOwner(resource.data.providerId)) || isAdmin();
      allow create: if isSignedIn() && isValidService(incoming());
      allow update: if isOwner(existing().providerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Applications & Registry
    match /applications/{appId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isValidApplication(incoming());
      allow update, delete: if isAdmin();
    }
    
    match /professionalApplications/{appId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isValidApplication(incoming());
      allow update, delete: if isAdmin();
    }

    // Inquiries System
    match /inquiries/{inquiryId} {
      allow read: if isOwner(resource.data.senderId) || isOwner(resource.data.receiverId) || isAdmin();
      allow create: if isSignedIn() && isValidInquiry(incoming());
      allow update, delete: if isAdmin();
    }

    // CMS & Articles System
    match /articles/{articleId} {
      allow read: if resource.data.published == true || isEditor();
      allow create: if isEditor() && isValidArticle(incoming());
      allow update: if isEditor();
      allow delete: if isEditor();
    }

    // Contact Messages
    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidContactMessage(incoming()); 
      allow update, delete: if isAdmin();
    }

    // Global Stats & Analytics
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy Admins Collection Check
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only populated via DB or root admin
    }

    // Trust Audit Logs
    match /trustAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // System only
    }
  }
}
