rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Bootstrapped Admin check
    function isSuperAdmin() {
      // Allow specific email as the initial admin
      return isSignedIn() && request.auth.token.email_verified == true && request.auth.token.email == 'towinnow0@gmail.com';
    }

    function isAdmin() {
      // Admin is either the super admin or a user explicitly given the role
      // Notice we use get() for role check if not super admin
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isAgent() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- VALIDATION BLUEPRINTS ---
    // Users
    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'role', 'name', 'createdAt', 'updatedAt']) &&
             data.keys().hasAny(['phone', 'avatarUrl', 'isApproved']) == false && 
             // we allow users to set phone etc., lets be exact
             data.size() >= 5 && data.size() <= 8 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'agent', 'user'] &&
             // Prevent non-superadmins from making themselves admins
             (data.role != 'admin' || isSuperAdmin()) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidUserUpdate(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'agent', 'user'] &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.updatedAt == request.time;
    }

    // Properties
    function isValidPropertyCreate(data) {
      return data.keys().hasAll(['agentId', 'title', 'description', 'type', 'listingType', 'price', 'location', 'city', 'status', 'createdAt', 'updatedAt']) &&
             data.size() >= 11 && data.size() <= 15 &&
             data.agentId == request.auth.uid && // Must be their own
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.type in ['house', 'apartment', 'land', 'commercial'] &&
             data.listingType in ['sale', 'rent'] &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() <= 512 &&
             data.city in ['Jigjiga', 'Dire Dawa', 'Godey', 'Dhagahbur', 'Kabridahar'] &&
             data.status == 'pending' && // Only admin can publish
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidPropertyUpdate(data) {
      return data.agentId == existing().agentId &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.type in ['house', 'apartment', 'land', 'commercial'] &&
             data.listingType in ['sale', 'rent'] &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() <= 512 &&
             data.city in ['Jigjiga', 'Dire Dawa', 'Godey', 'Dhagahbur', 'Kabridahar'] &&
             data.status in ['pending', 'published', 'rejected', 'sold', 'rented'] &&
             data.updatedAt == request.time;
    }

    // Vehicles
    function isValidVehicleCreate(data) {
      return data.keys().hasAll(['agentId', 'title', 'description', 'make', 'model', 'year', 'listingType', 'price', 'city', 'status', 'createdAt', 'updatedAt']) &&
             data.size() >= 12 && data.size() <= 15 &&
             data.agentId == request.auth.uid &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.make is string && data.make.size() <= 128 &&
             data.model is string && data.model.size() <= 128 &&
             data.year is number &&
             data.listingType in ['sale', 'rent'] &&
             data.price is number && data.price >= 0 &&
             data.city in ['Jigjiga', 'Dire Dawa', 'Godey', 'Dhagahbur', 'Kabridahar'] &&
             data.status == 'pending' &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }
    
    function isValidVehicleUpdate(data) {
       return data.agentId == existing().agentId &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.make is string && data.make.size() <= 128 &&
             data.model is string && data.model.size() <= 128 &&
             data.year is number &&
             data.listingType in ['sale', 'rent'] &&
             data.price is number && data.price >= 0 &&
             data.city in ['Jigjiga', 'Dire Dawa', 'Godey', 'Dhagahbur', 'Kabridahar'] &&
             data.status in ['pending', 'published', 'rejected', 'sold', 'rented'] &&
             data.updatedAt == request.time;
    }

    // Articles
    function isValidArticleCreate(data) {
      return data.keys().hasAll(['authorId', 'title', 'content', 'status', 'createdAt', 'updatedAt']) &&
             data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 512 &&
             data.content is string && data.content.size() <= 50000 &&
             data.status in ['draft', 'published'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }
    function isValidArticleUpdate(data) {
      return data.authorId == existing().authorId &&
             data.title is string && data.title.size() <= 512 &&
             data.content is string && data.content.size() <= 50000 &&
             data.status in ['draft', 'published'] &&
             data.updatedAt == request.time;
    }

    // Inquiries
    function isValidInquiryCreate(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() <= 256 &&
             data.email is string && data.email.size() <= 256 &&
             data.message is string && data.message.size() <= 5000 &&
             data.status == 'new' &&
             data.createdAt == request.time;
    }

    // Settings
    function isValidSettingUpdate(data) {
      return data.companyName is string && data.companyName.size() <= 256 &&
             data.phone is string && data.phone.size() <= 64 &&
             data.email is string && data.email.size() <= 256 &&
             data.updatedAt == request.time;
    }

    // --- MATCH BLOCKS ---

    match /users/{userId} {
      allow get: if isValidId(userId) && (isAdmin() || isOwner(userId));
      allow list: if isAdmin();
      allow create: if isValidId(userId) && isOwner(userId) && isValidUserCreate(incoming());
      allow update: if isValidId(userId) && isValidUserUpdate(incoming()) && (
        isAdmin() ||
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'avatarUrl', 'updatedAt']) && incoming().role == existing().role && incoming().isApproved == existing().isApproved)
      );
      allow delete: if isValidId(userId) && isAdmin();
    }

    match /properties/{propertyId} {
      allow get: if isValidId(propertyId) && (isAdmin() || (resource.data.status == 'published') || (isSignedIn() && resource.data.agentId == request.auth.uid));
      allow list: if isAdmin() || (resource.data.status == 'published') || (isSignedIn() && resource.data.agentId == request.auth.uid);
      allow create: if isValidId(propertyId) && isAgent() && isValidPropertyCreate(incoming());
      allow update: if isValidId(propertyId) && isValidPropertyUpdate(incoming()) && (
        isAdmin() ||
        (isAgent() && existing().agentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'location', 'bedrooms', 'bathrooms', 'area', 'images', 'updatedAt']) && incoming().status == existing().status)
      );
      allow delete: if isValidId(propertyId) && (isAdmin() || (isAgent() && existing().agentId == request.auth.uid));
    }

    match /vehicles/{vehicleId} {
      allow get: if isValidId(vehicleId) && (isAdmin() || (resource.data.status == 'published') || (isSignedIn() && resource.data.agentId == request.auth.uid));
      allow list: if isAdmin() || (resource.data.status == 'published') || (isSignedIn() && resource.data.agentId == request.auth.uid);
      allow create: if isValidId(vehicleId) && isAgent() && isValidVehicleCreate(incoming());
      allow update: if isValidId(vehicleId) && isValidVehicleUpdate(incoming()) && (
        isAdmin() ||
        (isAgent() && existing().agentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'images', 'updatedAt']) && incoming().status == existing().status)
      );
      allow delete: if isValidId(vehicleId) && (isAdmin() || (isAgent() && existing().agentId == request.auth.uid));
    }

    match /articles/{articleId} {
      allow get: if isValidId(articleId) && (isAdmin() || existing().status == 'published');
      allow list: if isAdmin() || existing().status == 'published';
      allow create: if isValidId(articleId) && isAdmin() && isValidArticleCreate(incoming());
      allow update: if isValidId(articleId) && isAdmin() && isValidArticleUpdate(incoming());
      allow delete: if isValidId(articleId) && isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get: if isValidId(inquiryId) && isAdmin();
      allow list: if isAdmin();
      allow create: if isValidId(inquiryId) && isValidInquiryCreate(incoming());
      allow update: if isValidId(inquiryId) && isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isValidId(inquiryId) && isAdmin();
    }

    match /settings/{settingId} {
      allow get: if isValidId(settingId); // Anyone needs basic company info
      allow list: if false; // Just get 'global' directly
      allow create: if false; // Must be created by admin script or manually but here we allow update
      allow update: if isValidId(settingId) && isAdmin() && isValidSettingUpdate(incoming());
    }
  }
}
